# Required: your Anthropic API key for headless Claude Code
# Get yours at https://console.anthropic.com/ — never commit a real key here
ANTHROPIC_API_KEY=

# Optional: link a markdown file as your shared roadmap
# Mac/Linux:  ROADMAP_PATH=/Users/you/notes/Roadmap.md
# Windows:    ROADMAP_PATH=C:\Users\you\notes\Roadmap.md
# ROADMAP_PATH=

# Optional: store agent signals in a shared directory (e.g. Dropbox, OneDrive)
# Defaults to .fleet/signals inside the Fleet project folder.
# Mac/Linux:  SIGNALS_DIR=/Users/you/shared/.agent-signals
# Windows:    SIGNALS_DIR=C:\Users\you\shared\.agent-signals
# SIGNALS_DIR=
